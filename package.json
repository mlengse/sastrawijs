{
  "name": "sastrawijs",
  "version": "1.1.0",
  "description": "Sastrawi is a simple javascript package which allows you to reduce inflected words in Indonesian Language (Bahasa Indonesia) to their base form (stem). Despite its simplicity, this library is designed to be high quality and well documented.",
  "main": "dist/sastrawijs.cjs.js",
  "module": "dist/sastrawijs.esm.mjs",
  "browser": "dist/sastrawijs.umd.js",
  "exports": {
    ".": {
      "require": "./dist/sastrawijs.cjs.js",
      "import": "./dist/sastrawijs.esm.mjs",
      "browser": "./dist/sastrawijs.umd.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "run-s build test test:pkg",
    "prepare": "husky",
    "build": "rollup -c",
    "test": "jest",
    "test:pkg": "check-export-map",
    "evaluate": "npm run build && node scripts/evaluate-kbbi.js"
  },
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mlengse/sastrawijs.git"
  },
  "keywords": [
    "stemmer",
    "nlp",
    "indonesia"
  ],
  "author": "mLengse (medotsys@gmail.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mlengse/sastrawijs/issues"
  },
  "homepage": "https://github.com/mlengse/sastrawijs",
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-jest": "^29.7.0",
    "check-export-map": "^1.0.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.11",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "rollup": "^4.28.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-typescript"
    ]
  },
  "jest": {
    "rootDir": "src",
    "transform": {
      "^.+\\.tsx?$": "babel-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  },
  "prettier": {
    "arrowParens": "avoid"
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2020": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:prettier/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "overrides": [
      {
        "files": [
          "src/**"
        ],
        "env": {
          "node": false
        }
      },
      {
        "files": [
          "**/__tests__/**"
        ],
        "extends": [
          "plugin:jest/recommended",
          "plugin:jest/style"
        ]
      }
    ]
  },
  "lint-staged": {
    "*.{js,ts}": "eslint --fix",
    "*.{js,ts,json,yml,yaml,md}": "prettier --write"
  }
}
